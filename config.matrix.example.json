  "diagnostics": {
    "backend": "none",
    "log_tool_calls": false,
    "log_message_receipts": false,
    "log_message_payloads": false,
    "log_llm_io": false,
    "token_usage_ledger_enabled": true,
    "token_usage_ledger_window_hours": 24,
    "token_usage_ledger_max_bytes": 0,
    "token_usage_ledger_max_lines": 0
