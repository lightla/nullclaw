  "runtime": {
    "kind": "native",
    "docker": {
      "image": "alpine:3.20",
      "network": "none",
      "memory_limit_mb": 512,
      "read_only_rootfs": true,
      "mount_workspace": true
    }
  },
  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500,
    "channel_initial_backoff_secs": 2,
    "channel_max_backoff_secs": 60,
    "scheduler_poll_secs": 15,
    "scheduler_retries": 2,
    "fallback_providers": [],
    "api_keys": [],
    "model_fallbacks": []
  },
  "scheduler": {
    "enabled": true,
    "max_tasks": 64,
    "max_concurrent": 4,
    "agent_timeout_secs": 0
  },
  "agent": {
    "compact_context": true,
    "max_tool_iterations": 1000,
    "max_history_messages": 100,
    "parallel_tools": false,
    "tool_dispatcher": "auto",
    "session_idle_timeout_secs": 1800,
    "compaction_keep_recent": 20,
    "compaction_max_summary_chars": 2000,
    "compaction_max_source_chars": 12000,
    "status_show_emojis": true,
    "message_timeout_secs": 600,
    "vision_disabled_models": [],
    "auto_disable_vision_on_error": true,
    "streaming": true
  },
  "channels": {
    "slack": {
      "accounts": {
        "dev_bot": {
          "bot_token": "xoxb-YOUR-BOT-TOKEN",
          "app_token": "xapp-YOUR-APP-TOKEN",
          "group_policy": "open",
          "allow_from": [
            "*"
          ],
          "reply_to_mode": "all",
          "channel_id": "C0ALEGSE15W"
        },
        "mentor_bot": {
          "bot_token": "xoxb-YOUR-BOT-TOKEN",
          "app_token": "xapp-YOUR-APP-TOKEN",
          "group_policy": "open",
          "allow_from": [
            "*"
          ],
          "reply_to_mode": "all",
          "channel_id": "C0ALEGSE15W"
        }
      }
    }
  },
  "memory": {
    "profile": "local_keyword",
    "backend": "sqlite",
    "auto_save": true,
    "lifecycle": {
