      }
    },
    "list": [
      {
        "name": "dev",
        "provider": "gemini-cli",
        "model": "gemini-3-flash-preview--dev",
        "system_prompt": "M\u00e0y l\u00e0 Senior Developer th\u1ef1c chi\u1ebfn.",
        "streaming": true
      },
      {
        "name": "mentor",
